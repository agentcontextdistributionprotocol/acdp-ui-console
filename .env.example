# ─── Demo mode ───────────────────────────────────────────────────────
# When true (default), every page works with rich mock data and no backend.
# Set to "false" to connect to the real playground / control-plane / registries.
NEXT_PUBLIC_ACDP_UI_DEMO_MODE=true

# ─── Upstream services (required when demo mode is false) ────────────
PLAYGROUND_BASE_URL=http://localhost:8000
CONTROL_PLANE_BASE_URL=http://localhost:3001
REGISTRY_A_BASE_URL=http://localhost:8100
REGISTRY_B_BASE_URL=http://localhost:8200

# ─── Auth ────────────────────────────────────────────────────────────
# Sent as a Bearer token on every control-plane request.
CONTROL_PLANE_API_KEY=

# ─── Observability ───────────────────────────────────────────────────
JAEGER_URL=http://localhost:16686
NEXT_PUBLIC_JAEGER_URL=http://localhost:16686

# ─── UI ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=0.1.0
